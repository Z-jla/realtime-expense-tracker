{
  "name": "realtime-expense-tracker",
  "private": false,
  "version": "1.0.0",
  "description": "手机优先的个人支出记账应用，支持手动记账、截图 OCR 自动入账和 Android APK 打包。",
  "license": "MIT",
  "author": "",
  "keywords": [
    "expense-tracker",
    "ocr",
    "react",
    "vite",
    "capacitor",
    "android",
    "pwa"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "android:sync": "npm run build && cap sync android",
    "android:debug": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-android-debug.ps1",
    "android:copy-debug-apk": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Copy-Item -LiteralPath 'android/app/build/outputs/apk/debug/app-debug.apk' -Destination '实时记账-debug.apk' -Force\""
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tesseract.js": "^7.0.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
